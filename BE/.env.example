PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5000,http://127.0.0.1:5000
TRUST_PROXY=0

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=utc_helpdesk
DB_CONNECTION_LIMIT=10
DB_TIMEZONE=+07:00

APP_TIME_ZONE=Asia/Ho_Chi_Minh
APP_TIME_OFFSET_MINUTES=420

JWT_SECRET=change_to_a_long_random_secret_before_deploy
JWT_EXPIRES_IN=7d
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20

UPLOAD_DIR=
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip

# OpenRouter public API: https://openrouter.ai/settings/keys
AI_PROVIDER=openrouter
AI_API_KEY=
AI_MODEL=openrouter/free
AI_TIMEOUT_MS=30000
AI_MAX_IMAGE_ATTACHMENTS=3
AI_MAX_IMAGE_MB=5
AI_CHAT_HISTORY_LIMIT=12
AI_CHAT_LOAD_LIMIT=50
AI_CHAT_MAX_MESSAGE_LENGTH=2000
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=20
APP_PUBLIC_URL=http://localhost:5000
